# Morning Briefing Bot - Environment Variables

# Supabase
VITE_SUPABASE_URL=https://your_project.supabase.co
VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Optional: Demo/Hackathon Mode
VITE_DEMO_AUTH_MODE=internal_key
VITE_DEMO_USER_ID=00000000-0000-0000-0000-000000000000

# Server-Side Internal Key (Matches Edge Function SECRET: INTERNAL_API_KEY)
# This is NOT the same as YOUR client-side VITE_ vars, but listed here for documentation.
# INTERNAL_API_KEY=your_secure_internal_key

# AI Providers (Server-Side Secrets)
# OPENAI_API_KEY=sk-...
# RUNWARE_API_KEY=...
# FAL_KEY=...
# VEED_API_KEY=...

# Avatar Provider: fal or veed
AVATAR_PROVIDER=fal
ENABLE_RUNWARE=true
MAX_BROLL_SEGMENTS=5
