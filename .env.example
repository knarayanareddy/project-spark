# Supabase
VITE_SUPABASE_URL=https://your_project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# Optional: Demo/Internal Key Mode
# Set to 'internal_key' to use the INTERNAL_API_KEY + VITE_DEMO_USER_ID for all calls
VITE_DEMO_AUTH_MODE=internal_key
VITE_DEMO_USER_ID=00000000-0000-0000-0000-000000000000

# Server-Side Internal Key (Matches Edge Function SECRET: INTERNAL_API_KEY)
INTERNAL_API_KEY=your_secure_internal_key

# OAuth Config (Server-Side Secrets)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# AI Providers (Server-Side Secrets)
OPENAI_API_KEY=sk-...
RUNWARE_API_KEY=...
FAL_KEY=...
CONNECTOR_SECRET_KEY=your_32_char_encryption_key

# Video Configuration
AVATAR_PROVIDER=fal
ENABLE_RUNWARE=true
MAX_BROLL_SEGMENTS=5
